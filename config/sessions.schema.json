{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OMC Session Manager Configuration",
  "type": "object",
  "required": ["version", "authorizedUsers", "master", "sessions", "healthCheck"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "const": 1,
      "description": "Configuration schema version"
    },
    "authorizedUsers": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "description": "List of authorized Telegram user IDs"
    },
    "master": {
      "type": "object",
      "required": ["credentialKey", "notifyChatId"],
      "additionalProperties": false,
      "properties": {
        "credentialKey": {
          "type": "string",
          "description": "Credential store key for the master bot token"
        },
        "notifyChatId": {
          "type": "string",
          "description": "Telegram chat ID for notifications"
        }
      }
    },
    "sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "credentialKey"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1,
            "maximum": 99,
            "description": "Unique session identifier"
          },
          "name": {
            "type": "string",
            "description": "Human-readable session name"
          },
          "credentialKey": {
            "type": "string",
            "description": "Credential store key for the session bot token"
          },
          "botUsername": {
            "type": "string",
            "description": "Telegram bot username for this session (without @)"
          },
          "defaultMode": {
            "type": "string",
            "enum": ["yolo", "normal", "plan"],
            "description": "Default Claude Code mode for this session"
          },
          "workingDirectory": {
            "type": "string",
            "description": "Working directory for the session"
          },
          "autoStart": {
            "type": "boolean",
            "description": "Whether to start this session automatically on boot"
          },
          "autoRestart": {
            "type": "boolean",
            "description": "Whether to restart this session on crash"
          },
          "maxRestarts": {
            "type": "integer",
            "default": 3,
            "description": "Maximum number of automatic restarts"
          }
        }
      }
    },
    "healthCheck": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "intervalSeconds": {
          "type": "integer",
          "minimum": 10,
          "default": 30,
          "description": "Health check interval in seconds"
        },
        "unresponsiveThreshold": {
          "type": "integer",
          "minimum": 60,
          "default": 300,
          "description": "Seconds before a session is considered unresponsive"
        }
      }
    }
  }
}
